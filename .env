# Database configuration - SQLite for testing/development
# For production use PostgreSQL:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=airport_sim
# DATABASE_USER=postgres
# DATABASE_PASSWORD=${DATABASE_PASSWORD}
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3

# Secret key - for testing/development only
SECRET_KEY=test-secret-key-for-development-only-change-in-production

# Debug mode - MUST be False in production!
DEBUG=True

# Allowed hosts - comma-separated for production
ALLOWED_HOSTS=localhost,127.0.0.1

# Security settings
SECURE_SSL_REDIRECT=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SECURE=False

# Redis cache (for production scalability)
# REDIS_URL=redis://127.0.0.1:6379/1
