# =============================================================================
# Blue Falcon - Git Ignore Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
local_settings.py

# -----------------------------------------------------------------------------
# Virtual Environment
# -----------------------------------------------------------------------------
venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Environment Variables (KEEP .env IN PROJECT ROOT FOR CONFIGURATION)
# -----------------------------------------------------------------------------
# Note: .env is kept for local development but should not contain secrets
# Use environment variables for production secrets
.env.secret
.env.*.secret

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/
.hypothesis/

# -----------------------------------------------------------------------------
# Node modules (if used)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Never commit local sqlite databases.
db.sqlite3
db.sqlite3-journal

# -----------------------------------------------------------------------------
# Migration files - Keep for version control
# -----------------------------------------------------------------------------
# All migrations are kept for proper version control
# Only __pycache__ inside migrations is ignored (see Python section)

# -----------------------------------------------------------------------------
# Static and Media files
# -----------------------------------------------------------------------------
# staticfiles/ is generated by collectstatic - should not be committed
staticfiles/
# media/ is for user uploads - should not be committed
/media/
mediafiles/

# -----------------------------------------------------------------------------
# Security files
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
# Never commit logs.
logs/
*.log

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Q cluster (Django-Q2)
# -----------------------------------------------------------------------------
django_q_cluster.db

# -----------------------------------------------------------------------------
# Backup files
# -----------------------------------------------------------------------------
backups/
*.bak
